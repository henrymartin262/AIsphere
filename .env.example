# ============================================
# SealMind 环境变量配置
# 复制为 .env 并填写实际值
# cp .env.example .env
# ============================================

# --- 0G Chain (Testnet) ---
RPC_URL=https://16602.rpc.thirdweb.com
CHAIN_ID=16602
# 后端服务钱包私钥（需要有少量 0G 测试网代币）
PRIVATE_KEY=
# 部署钱包私钥（如需重新部署合约）
DEPLOYER_PRIVATE_KEY=

# --- 0G Storage ---
STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
KV_NODE_URL=http://3.101.147.150:6789

# --- 0G Compute ---
# Sealed Inference 通过 broker SDK 自动发现，无需手动配置

# --- 合约地址（0G 测试网 Chain ID: 16602，已部署）---
INFT_ADDRESS=0x1f29Bd4E0426222a78Ce0D484677A672DF3E8fa6
DECISION_CHAIN_ADDRESS=0x354306105a61505EB9a01A142E9fCA537E102EC2
REGISTRY_ADDRESS=0x127b73133c9Ba241dE1d1ADdc366c686fd499c02

# --- 前端 ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_CHAIN_ID=16602
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_INFT_ADDRESS=0x1f29Bd4E0426222a78Ce0D484677A672DF3E8fa6
NEXT_PUBLIC_DECISION_CHAIN_ADDRESS=0x354306105a61505EB9a01A142E9fCA537E102EC2
NEXT_PUBLIC_REGISTRY_ADDRESS=0x127b73133c9Ba241dE1d1ADdc366c686fd499c02

# --- 主网配置（主网部署时取消注释，替换合约地址）---
